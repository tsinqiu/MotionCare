HOST=127.0.0.1
PORT=8089

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=MotionAnalysis
DB_USER=root
DB_PASSWORD=

CORS_ORIGIN=http://localhost:5173

JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
LOGIN_FAILURE_WINDOW_MS=600000
LOGIN_FAILURE_MAX=5
LOGIN_BLOCK_MINUTES=10

STATS_CACHE_TTL_SECONDS=60

ML_PYTHON_PATH=python
ML_PREDICT_SCRIPT=./ml/predict_running.py
ML_MODEL_PATH=./ml/models/running_model.joblib

HOST=127.0.0.1
PORT=8089

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=MotionAnalysis
DB_USER=motion_api
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

CORS_ORIGIN=http://your_server_public_ip

JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

TRUST_PROXY=true
JSON_BODY_LIMIT=1mb
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
LOGIN_FAILURE_WINDOW_MS=600000
LOGIN_FAILURE_MAX=5
LOGIN_BLOCK_MINUTES=10

STATS_CACHE_TTL_SECONDS=60

ML_PYTHON_PATH=python3
ML_PREDICT_SCRIPT=./ml/predict_running.py
ML_MODEL_PATH=./ml/models/running_model.joblib
ML_TIMEOUT_MS=10000

GARMIN_PYTHON_PATH=python3
GARMIN_DOWNLOAD_SCRIPT=/var/www/motion-analysis/database/scripts/download_garmin_connect.py
GARMIN_IMPORT_SCRIPT=/var/www/motion-analysis/database/scripts/import_fit_files.py
GARMIN_HEALTH_IMPORT_SCRIPT=/var/www/motion-analysis/database/scripts/import_garmin_health.py
GARMIN_TOKEN_BASE_DIR=/var/lib/motion-analysis/garmin_tokens/users
GARMIN_SYNC_WORK_DIR=/var/lib/motion-analysis/garmin_sync
GARMIN_JSON_MODE=summary
GARMIN_CHUNK_DAYS=14
GARMIN_CHUNK_SLEEP_SECONDS=10
GARMIN_SLEEP_SECONDS=1.5
GARMIN_EXTRA_SLEEP_SECONDS=0.5
GARMIN_RETRIES=2
GARMIN_SYNC_TIMEOUT_MS=900000
